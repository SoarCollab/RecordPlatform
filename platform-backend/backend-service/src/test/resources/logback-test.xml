<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n%nopex</pattern>
        </encoder>
    </appender>

    <logger name="cn.flying.service.impl.FileUploadServiceImpl" level="ERROR"/>
    <logger name="cn.flying.service.impl.SystemMonitorServiceImpl" level="ERROR"/>
    <logger name="cn.flying.common.util.JsonConverter" level="WARN"/>
    <logger name="org.springframework.test" level="WARN"/>
    <logger name="org.testcontainers" level="WARN"/>
    <logger name="com.github.dockerjava" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>

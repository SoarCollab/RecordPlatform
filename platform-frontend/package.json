{
  "name": "platform-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "types:gen": "openapi-typescript \"${OPENAPI_SOURCE:-http://localhost:8000/record-platform/v3/api-docs}\" -o src/lib/api/types/generated.ts",
    "types:gen:check": "pnpm types:gen && git diff --exit-code -- src/lib/api/types/generated.ts",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest",
    "test:coverage": "svelte-kit sync && vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.575.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.52.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@types/node": "^22.10.1",
    "@vitest/coverage-v8": "^2.1.8",
    "bits-ui": "^2.16.2",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^2.46.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.10",
    "openapi-typescript": "7.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.3",
    "svelte-check": "^4.4.3",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "mode-watcher": "^1.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "type": "module",
  "lint-staged": {
    "*.{js,ts,svelte,html,css,json}": "prettier --write",
    "*.{js,ts,svelte}": "eslint --fix"
  },
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa"
}

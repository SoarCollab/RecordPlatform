# ==============================================================================
# RecordPlatform 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到版本控制系统
#
# 重要：数据库、Redis、邮件、RabbitMQ 等敏感配置已迁移至 Nacos 配置中心
#
# ==============================================================================

# ==============================================================================
# Nacos 配置中心
# ==============================================================================
NACOS_HOST=localhost
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_USERNAME=replace_with_nacos_username
NACOS_PASSWORD=replace_with_strong_nacos_password

# ==============================================================================
# 基础设施服务凭据 (docker-compose.infra.yml)
# ==============================================================================
# 安全默认值：Compose 默认只绑定 127.0.0.1。生产/服务器部署前必须填写强随机凭据。
INFRA_BIND_ADDRESS=127.0.0.1
OBSERVABILITY_BIND_ADDRESS=127.0.0.1
DB_PORT=3306
DB_PASSWORD=replace_with_strong_database_password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_strong_redis_password
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=replace_with_rabbitmq_username
RABBITMQ_PASSWORD=replace_with_strong_rabbitmq_password
NACOS_AUTH_TOKEN=replace_with_base64_32_byte_or_longer_nacos_auth_token
NACOS_AUTH_IDENTITY_KEY=replace_with_nacos_identity_key_name
NACOS_AUTH_IDENTITY_VALUE=replace_with_strong_nacos_identity_secret

# ==============================================================================
# Knife4j API 文档配置 (开发环境)
# ==============================================================================
KNIFE4J_USERNAME=replace_with_knife4j_username
KNIFE4J_PASSWORD=replace_with_strong_knife4j_password

# ==============================================================================
# S3 兼容对象存储
# ==============================================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=replace_with_minio_access_key
S3_SECRET_KEY=replace_with_strong_minio_secret_key
S3_BUCKET_NAME=forum
MINIO_A_API_PORT=9000
MINIO_A_CONSOLE_PORT=9001
MINIO_B_API_PORT=9010
MINIO_B_CONSOLE_PORT=9011

# ==============================================================================
# 安全配置
# ==============================================================================
# JWT 密钥 (建议使用 32 字符以上的随机字符串)
# 同时用于 ID 加密密钥派生，无需额外配置
JWT_KEY=your_jwt_secret_key_at_least_32_characters
PUBLIC_REGISTRATION_TENANT_ID=0
# 后端调用 FISCO Dubbo provider 的共享令牌，backend 与 fisco 必须保持一致
BLOCKCHAIN_RPC_TOKEN=replace_with_strong_blockchain_rpc_token

# UID 编码器配置 (用于用户 ID 混淆)
# SALT: 建议 8-16 字符随机字符串
# CLIENT_KEY: 建议 16-32 字符随机字符串
RECORD_PLATFORM_UID_SALT=
RECORD_PLATFORM_CLIENT_KEY=

# ==============================================================================
# CORS 配置
# ==============================================================================
# 允许的前端域名，多个用逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==============================================================================
# FISCO BCOS 区块链配置
# ==============================================================================
FISCO_PEER_ADDRESS=127.0.0.1:20200
FISCO_GROUP_ID=group0
FISCO_CERT_PATH=conf
FISCO_PRIVATE_KEY=
# 合约地址 (部署后更新)
FISCO_SHARING_CONTRACT=0x6d5de407db930fd7f5a0d9f19be7ec7bc7b36a2a
FISCO_STORAGE_CONTRACT=0xe7d7b002e51431b300ddc00b2c059ccc41ce4660

# ==============================================================================
# 服务端口配置
# ==============================================================================
# Backend Web API 端口 (生产环境 80，开发环境 8000)
SERVER_PORT=8000

# Dubbo Triple 协议端口
DUBBO_FISCO_PORT=8091
DUBBO_STORAGE_PORT=8092

# Dubbo 服务注册 IP (用于 Docker 环境，避免注册 Docker 网桥 IP)
# 设置为服务器内网 IP，确保 Consumer 能访问 Provider
DUBBO_HOST=127.0.0.1

# Dubbo QoS 管理端口
QOS_BACKEND_PORT=22330
QOS_FISCO_PORT=22331
QOS_STORAGE_PORT=22332

# ==============================================================================
# 日志配置
# ==============================================================================
LOG_LEVEL=INFO
LOG_PATH=/var/log/record-platform

# ==============================================================================
# SkyWalking APM (可选)
# ==============================================================================
SW_AGENT_COLLECTOR_BACKEND_SERVICES=localhost:11800
SW_AGENT_NAME=record-platform
# SQL 参数可能包含文件密钥、分享码或令牌；仅在脱敏测试环境显式改为 true。
SW_JDBC_TRACE_SQL_PARAMETERS=false

# ==============================================================================
# OpenTelemetry Configuration (可选, 启用 --otel 或 Docker 部署时使用)
# ==============================================================================
# OTLP exporter endpoint (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=8889
JAEGER_UI_PORT=16686
# Sampling strategy: parentbased_traceidratio, always_on, always_off
OTEL_TRACES_SAMPLER=parentbased_traceidratio
# Sampling ratio (0.0 ~ 1.0, 0.1 = 10% of traces)
OTEL_TRACES_SAMPLER_ARG=0.1

# ==============================================================================
# Spring Profile
# ==============================================================================
# 可选值: local, dev, prod
SPRING_PROFILES_ACTIVE=local
